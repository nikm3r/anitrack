{
  "name": "anitrack",
  "version": "0.4.15",
  "description": "Anime tracking desktop app",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:server": "tsx watch server/index.ts",
    "build": "npm run build:server && vite build",
    "build:server": "node esbuild.config.js",
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "package": "npm run build && electron-builder build",
    "make": "npm run build && electron-builder build",
    "publish": "npm run build && electron-builder build --publish always"
  },
  "keywords": [],
  "author": "nikm3r <nmermigkas@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "better-sqlite3": "11.10.0",
    "cors": "^2.8.5",
    "electron-updater": "^6.3.0",
    "express": "^4.21.0",
    "lucide-react": "^0.577.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "tailwindcss": "^4.0.0"
  }
}
